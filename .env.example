# Supabase (required for web + Telegram)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Opsional: URL app untuk redirect konfirmasi email / reset password (tanpa trailing slash). Kalau kosong, dipakai default production.
# NEXT_PUBLIC_APP_URL=https://finance-tracker-gamma-livid.vercel.app

# Telegram Bot (required for webhook)
TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
# TELEGRAM_USER_ID (opsional): fallback satu user kalau belum pakai fitur Link Telegram. Untuk multi-user, setiap orang hubungkan lewat dashboard → Link Telegram.
# TELEGRAM_SET_WEBHOOK_SECRET (opsional): rahasia untuk endpoint /api/telegram/set-webhook agar hanya kamu yang bisa panggil.

# Ringkasan mingguan lewat bot (opsional). Set di Vercel → Cron akan panggil /api/cron/weekly-summary. Untuk panggil manual: GET dengan header Authorization: Bearer <CRON_SECRET>.
# CRON_SECRET=rahasia-cron-kamu
