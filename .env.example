# Supabase (required for web + Telegram)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Opsional: URL app untuk redirect konfirmasi email / reset password (tanpa trailing slash).
# Wajib di production agar link di email mengarah ke domain yang benar. Di Supabase Dashboard → Authentication → URL Configuration, tambahkan URL ini ke Redirect URLs.
# NEXT_PUBLIC_APP_URL=https://finance-tracker-gamma-livid.vercel.app

# Telegram Bot (required for webhook)
TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
# TELEGRAM_USER_ID (opsional): fallback satu user kalau belum pakai fitur Link Telegram. Untuk multi-user, setiap orang hubungkan lewat dashboard → Link Telegram.
# TELEGRAM_SET_WEBHOOK_SECRET (opsional): rahasia untuk endpoint /api/telegram/set-webhook agar hanya kamu yang bisa panggil.

# Ringkasan mingguan lewat bot (opsional). Set di Vercel → Cron akan panggil /api/cron/weekly-summary. Untuk panggil manual: GET dengan header Authorization: Bearer <CRON_SECRET>.
# CRON_SECRET=rahasia-cron-kamu

# AI untuk parsing foto struk & chatbot. Set minimal 1, idealnya semua 3 untuk fallback otomatis:
#   Prioritas: Gemini Flash → Groq → OpenRouter (jika provider 1 limit/error, otomatis pindah ke berikutnya)
#
# 1. Gemini Flash (paling generous: 1500 req/hari gratis) — https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key
#
# 2. Groq (super cepat, ~14400 req/hari gratis) — https://console.groq.com/keys
# GROQ_API_KEY=your-groq-api-key
#
# 3. OpenRouter (200 req/hari per model gratis) — https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-openrouter-api-key
